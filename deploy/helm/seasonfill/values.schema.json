{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Seasonfill Helm values",
  "type": "object",
  "additionalProperties": true,
  "required": ["secrets", "database"],
  "properties": {
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "existingSecret": {"type": "string"},
        "apiKey":          {"type": "string"},
        "webUser":         {"type": "string"},
        "webPassword":     {"type": "string"},
        "webPasswordHash": {"type": "string"},
        "postgresDSN":     {"type": "string"},
        "oidcClientSecret": {"type": "string", "default": ""},
        "keys": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "apiKey", "webUser", "webPassword", "webPasswordHash",
            "postgresDSN"
          ],
          "properties": {
            "apiKey":          {"type": "string", "minLength": 1},
            "webUser":         {"type": "string", "minLength": 1},
            "webPassword":     {"type": "string", "minLength": 1},
            "webPasswordHash": {"type": "string", "minLength": 1},
            "postgresDSN":     {"type": "string", "minLength": 1},
            "oidcClientSecret": {"type": "string", "default": "oidc-client-secret"}
          }
        }
      },
      "allOf": [
        {
          "description": "mutex: webPassword and webPasswordHash cannot both be non-empty",
          "not": {
            "allOf": [
              {"properties": {"webPassword":     {"type": "string", "minLength": 1}}, "required": ["webPassword"]},
              {"properties": {"webPasswordHash": {"type": "string", "minLength": 1}}, "required": ["webPasswordHash"]}
            ]
          }
        },
        {
          "description": "mutex: existingSecret cannot be combined with any inline secrets.* values.",
          "not": {
            "allOf": [
              {"properties": {"existingSecret": {"type": "string", "minLength": 1}}, "required": ["existingSecret"]},
              {
                "anyOf": [
                  {"properties": {"apiKey":          {"type": "string", "minLength": 1}}, "required": ["apiKey"]},
                  {"properties": {"webUser":         {"type": "string", "minLength": 1}}, "required": ["webUser"]},
                  {"properties": {"webPassword":     {"type": "string", "minLength": 1}}, "required": ["webPassword"]},
                  {"properties": {"webPasswordHash": {"type": "string", "minLength": 1}}, "required": ["webPasswordHash"]},
                  {"properties": {"postgresDSN":     {"type": "string", "minLength": 1}}, "required": ["postgresDSN"]}
                ]
              }
            ]
          }
        }
      ]
    },
    "database": {
      "type": "object",
      "additionalProperties": true,
      "required": ["driver"],
      "properties": {
        "driver": {"type": "string", "enum": ["sqlite", "postgres"]},
        "sqlite": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "path": {"type": "string"}
          }
        }
      }
    },
    "log": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "level":  {"type": "string", "enum": ["debug", "info", "warn", "error"]},
        "format": {"type": "string", "enum": ["json", "text"]}
      }
    },
    "http": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "bind": {"type": "string"}
      }
    },
    "oidc": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean", "default": false}
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {"type": "boolean"},
        "host":    {"type": "string"},
        "tls": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled":    {"type": "boolean"},
            "secretName": {"type": "string"}
          }
        }
      },
      "allOf": [
        {
          "description": "ingress.host required when ingress.enabled is true",
          "if":   {"properties": {"enabled": {"const": true}}, "required": ["enabled"]},
          "then": {"required": ["host"], "properties": {"host": {"type": "string", "minLength": 1}}}
        },
        {
          "description": "ingress.tls.secretName required when tls.enabled is true",
          "if":   {"properties": {"tls": {"properties": {"enabled": {"const": true}}, "required": ["enabled"]}}, "required": ["tls"]},
          "then": {"properties": {"tls": {"required": ["secretName"], "properties": {"secretName": {"type": "string", "minLength": 1}}}}}
        }
      ]
    }
  }
}
