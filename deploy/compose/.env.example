# ---------------------------------------------------------------------
# Seasonfill — docker-compose env file.
#
# Copy to `.env` (same dir as docker-compose.yaml) and tweak as needed.
# Everything is OPTIONAL on a fresh install — the backend auto-generates
# an API key + admin password on first start and prints them ONCE to
# the logs with a FIRST-RUN banner.
#
# After first start, capture the printed SEASONFILL_API_KEY value and
# paste it back here, otherwise the backend will refuse to start (the
# DB holds AES-GCM-encrypted Sonarr instance secrets that need this
# key to decrypt).
# ---------------------------------------------------------------------

# Database.
#   - Default: SQLite at /data/seasonfill.db inside the backend
#     container (persisted to the `seasonfill-data` named volume).
#   - For Postgres: set SEASONFILL_DATABASE_DRIVER=postgres and
#     SEASONFILL_DATABASE_POSTGRES_DSN.
SEASONFILL_DATABASE_DRIVER=sqlite
# SEASONFILL_DATABASE_SQLITE_PATH=/data/seasonfill.db
SEASONFILL_DATABASE_POSTGRES_DSN=

# HTTP + logging.
SEASONFILL_HTTP_BIND=:8080
SEASONFILL_LOG_LEVEL=info
SEASONFILL_LOG_FORMAT=json

# Encryption key (HKDF input for AES-GCM at-rest secrets).
# Leave EMPTY on first start to let the backend auto-generate one and
# print it ONCE in the FIRST-RUN banner. Paste the printed value back
# here before the next restart.
SEASONFILL_API_KEY=

# Authentication
#   Credentials for the built-in admin account.
#   CHANGE ME — these are example credentials for a quick-start compose deploy.
#   Rotate via UI Settings → Security after first login.
#   Leave SEASONFILL_WEB_PASSWORD empty (and delete/comment it below) for
#   auto-generated first-run password printed once to logs. SEASONFILL_WEB_PASSWORD
#   and SEASONFILL_WEB_PASSWORD_HASH are mutually exclusive.
#
#   Auth mode (Forms / Basic / None) is a runtime setting — configure in
#   UI Settings → Security after first login. No restart needed.
SEASONFILL_WEB_USER=admin
SEASONFILL_WEB_PASSWORD=admin
# SEASONFILL_WEB_PASSWORD_HASH=

# Image tag override. Default `latest`.
# TAG=0.6.1

# Host port for the frontend. Default 8080. Bump if 8080 is busy.
# WEB_PORT=8080
