# ---------------------------------------------------------------------
# Seasonfill — docker-compose env file.
#
# Copy to `.env` (same dir as docker-compose.yaml) and fill in. The
# compose stack reads ${VAR:-default} from here; missing required vars
# (marked REQUIRED) will cause `docker compose up` to abort.
# ---------------------------------------------------------------------

# REQUIRED — 32-byte HMAC signing key + service-to-service API key.
# Generate: openssl rand -hex 32
SEASONFILL_API_KEY=

# Web UI credentials.
#   - SEASONFILL_WEB_USER defaults to `admin`.
#   - Leave SEASONFILL_WEB_PASSWORD empty for the FIRST-RUN flow: the
#     backend will auto-generate a random 24-char password, bcrypt-hash
#     it, persist it, and print the plaintext ONCE to the backend logs
#     with a "FIRST-RUN PASSWORD" banner. Capture it from
#     `docker compose logs backend | grep FIRST-RUN`. After login, the
#     UI shows a banner prompting you to change the password.
#   - If you have a pre-hashed bcrypt string, set SEASONFILL_WEB_PASSWORD_HASH
#     instead (mutually exclusive with SEASONFILL_WEB_PASSWORD).
SEASONFILL_WEB_USER=admin
SEASONFILL_WEB_PASSWORD=
# SEASONFILL_WEB_PASSWORD_HASH=

# Cookie security.
#   - `false` (default) for plain HTTP (http://localhost:8080 or a
#     reverse proxy that does NOT terminate TLS). Browsers will reject
#     Secure cookies over HTTP, so do not flip to true until your
#     reverse proxy actually serves HTTPS.
#   - `true` when fronted by Caddy/Traefik/nginx with a TLS cert.
SEASONFILL_AUTH_SECURE_COOKIE=false

# Database.
#   - Default: SQLite at /data/seasonfill.db inside the backend
#     container (persisted to the `seasonfill-data` named volume).
#   - For Postgres, set POSTGRES_DSN AND set DB_DRIVER=postgres:
#       POSTGRES_DSN=postgres://user:pass@host:5432/seasonfill?sslmode=require
DB_DRIVER=sqlite
# SQLITE_PATH=/data/seasonfill.db
POSTGRES_DSN=

# Sonarr instance(s). config.example.yaml references ${SONARR_MAIN_URL}
# and ${SONARR_MAIN_API_KEY}. To add more instances:
#   1. Define SONARR_<NAME>_URL and SONARR_<NAME>_API_KEY pairs here.
#   2. Add a matching `- name: ...` block to config.yaml that
#      interpolates them.
SONARR_MAIN_URL=
SONARR_MAIN_API_KEY=

# Image tag override. Default `latest`. Pin to a chart release for
# production:
# TAG=0.3.0

# Host port for the frontend. Default 8080. Bump if 8080 is busy.
# WEB_PORT=8080

# Backend log level. Default `info`. Use `debug` for troubleshooting.
# LOG_LEVEL=info
